{
  "manifest_version": 3,
  "name": "Send to Reading Room",
  "description": "Save web pages directly to your Reading Room.",
  "version": "1.0",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to Reading Room"
  }
}
