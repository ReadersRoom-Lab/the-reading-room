# PostgreSQL connection string
# Local: postgresql://postgres:postgres@localhost:5432/readers_room
# Supabase: find in Project Settings → Database → Connection string (URI)
DATABASE_URL="postgresql://user:password@localhost:5432/readers_room"

# Clerk authentication keys
# Get from https://dashboard.clerk.com → your app → API Keys
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."

# Clerk webhook secret — used to verify events from Clerk
# Set up a webhook at https://dashboard.clerk.com → Webhooks pointing to /api/webhooks/clerk
# Events needed: user.created, user.updated
CLERK_WEBHOOK_SECRET="whsec_..."

# Google Generative AI — used for AI chat and synthesis features
# Get from https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY="AIza..."
