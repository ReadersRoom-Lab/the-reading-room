{
  "name": "readers-room",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/build-extension-zip.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --import tsx --test tests/*.test.ts",
    "test:coverage": "c8 --reporter=lcov --reporter=text --all --include=lib/**/*.ts --exclude=lib/prisma.ts --exclude=lib/embeddings.ts node --import tsx --test tests/*.test.ts",
    "api:smoke": "node --import tsx ./scripts/api-smoke.ts",
    "postinstall": "prisma generate",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/google": "^0.0.52",
    "@base-ui/react": "^1.6.0",
    "@clerk/nextjs": "^7.5.10",
    "@clerk/ui": "^1.24.1",
    "@mozilla/readability": "^0.6.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^3.4.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "fflate": "^0.8.3",
    "linkedom": "^0.18.12",
    "lucide-react": "^1.22.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "pdfjs-dist": "^6.1.200",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sanitize-html": "^2.17.5",
    "sonner": "^2.0.7",
    "svix": "^1.96.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "c8": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "knip": "^6.25.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "tailwindcss": "^4",
    "tsx": "^4.20.4",
    "typescript": "^5"
  },
  "optionalDependencies": {
    "bufferutil": "^4.0.1",
    "utf-8-validate": "^5.0.10"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "README.md": [
      "node scripts/generate-contributions.mjs",
      "prettier --write CONTRIBUTIONS.md",
      "git add CONTRIBUTIONS.md"
    ]
  }
}
