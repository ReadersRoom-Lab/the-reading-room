generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String        @id @default(uuid())
  clerk_id      String        @unique
  email         String        @unique
  name          String?
  tier          String        @default("free")
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt
  rooms         Room[]
  articles      Article[]
  highlights    Highlight[]
  vaultEntries  VaultEntry[]

  @@index([clerk_id])
}

model Room {
  id           String       @id @default(uuid())
  user_id      String
  user         User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  name         String
  description  String?
  cover_color  String
  mode         String       @default("reading")
  created_at   DateTime     @default(now())
  updated_at   DateTime     @updatedAt
  articles     Article[]
  vaultTrails  VaultTrail[]

  @@index([user_id])
}

model Article {
  id                String       @id @default(uuid())
  user_id           String
  user              User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  room_id           String?
  room              Room?        @relation(fields: [room_id], references: [id], onDelete: SetNull)
  title             String
  author            String?
  source_url        String
  source_type       String       @default("url")
  content           String
  cover_image       String?
  reading_progress  Int          @default(0)
  status            String       @default("unread")
  word_count        Int          @default(0)
  read_time_minutes Int          @default(0)
  date_accessed     DateTime     @default(now())
  created_at        DateTime     @default(now())
  updated_at        DateTime     @updatedAt
  highlights        Highlight[]
  vaultTrails       VaultTrail[]

  @@index([user_id])
  @@index([room_id])
}

model Highlight {
  id               String   @id @default(uuid())
  article_id       String
  article          Article  @relation(fields: [article_id], references: [id], onDelete: Cascade)
  user_id          String
  user             User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  content          String
  colour           String
  note             String?
  position_start   Int
  position_end     Int
  created_at       DateTime @default(now())
  annotation_type  String?

  @@index([article_id])
  @@index([user_id])
}

model VaultEntry {
  id               String       @id @default(uuid())
  user_id          String
  user             User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  term             String
  type             String
  definition       String
  pronunciation    String?
  etymology        String?
  example_sentence String?
  user_note        String?
  created_at       DateTime     @default(now())
  vaultTrails      VaultTrail[]

  @@index([user_id])
}

model VaultTrail {
  id              String      @id @default(uuid())
  vault_entry_id  String
  vault_entry     VaultEntry  @relation(fields: [vault_entry_id], references: [id], onDelete: Cascade)
  article_id      String
  article         Article     @relation(fields: [article_id], references: [id], onDelete: Cascade)
  room_id         String?
  room            Room?       @relation(fields: [room_id], references: [id], onDelete: SetNull)
  passage         String
  found_at        DateTime    @default(now())

  @@index([vault_entry_id])
  @@index([article_id])
  @@index([room_id])
}
